{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["id", "email", "name", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product in inventory",
      "type": "object",
      "properties": {
        "barcode": { "type": "string" },
        "name": { "type": "string" },
        "buyPrice": { "type": "number" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "stokKodu": { "type": "string" },
        "marka": { "type": "string" },
        "model": { "type": "string" },
        "renk": { "type": "string" },
        "beden": { "type": "string" },
        "anaStokKodu": { "type": "string" },
        "group": { "type": "string" },
        "midGroup": { "type": "string" },
        "subGroup": { "type": "string" },
        "supplierId": { "type": "string" },
        "isDeleted": { "type": "boolean" },
        "isActivated": { "type": "boolean" }
      },
      "required": ["barcode", "name", "buyPrice", "price", "stock", "stokKodu"]
    },
    "SaleRecord": {
      "title": "SaleRecord",
      "description": "Record of a sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "total": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string", "enum": ["Nakit", "Kredi Kartı"] },
        "customerId": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["id", "total", "date", "paymentMethod", "items"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Product supplier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "name"]
    },
    "CompanyInfo": {
      "title": "CompanyInfo",
      "description": "Company settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "appTitle": { "type": "string" }
      },
      "required": ["name", "appTitle"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "SimpleEntity": {
      "title": "SimpleEntity",
      "description": "Generic simple entity (brand, model, color, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "MissingListRecord": {
      "title": "MissingListRecord",
      "description": "Record of a generated missing list",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "items": { "type": "array" },
        "totalQuantity": { "type": "number" },
        "totalCost": { "type": "number" }
      },
      "required": ["id", "date", "supplierId", "supplierName", "items", "totalQuantity", "totalCost"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{barcode}": {
      "schema": "Product",
      "description": "Inventory products"
    },
    "/salesHistory/{saleId}": {
      "schema": "SaleRecord",
      "description": "Sales records"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Suppliers list"
    },
    "/companyInfo/settings": {
      "schema": "CompanyInfo",
      "description": "Company settings"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customers list"
    },
    "/brands/{id}": { "schema": "SimpleEntity", "description": "Brands" },
    "/models/{id}": { "schema": "SimpleEntity", "description": "Models" },
    "/colors/{id}": { "schema": "SimpleEntity", "description": "Colors" },
    "/sizes/{id}": { "schema": "SimpleEntity", "description": "Sizes" },
    "/groups/{id}": { "schema": "SimpleEntity", "description": "Groups" },
    "/purchaseHistory/{id}": { "schema": "object", "description": "Purchase history" },
    "/paymentHistory/{id}": { "schema": "object", "description": "Payment history" },
    "/returnHistory/{id}": { "schema": "object", "description": "Return history" },
    "/endOfDayHistory/{id}": { "schema": "object", "description": "End of day history" },
    "/missingLists/{id}": { "schema": "MissingListRecord", "description": "Saved missing lists" }
  }
}
